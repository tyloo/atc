{
    "name": "tyloo/atc",
    "type": "library",
    "license": "MIT",
    "description": "Fluent API testing for Symfony with JSON Schema validation, container mocking, and in-memory infrastructure swaps.",
    "keywords": [
        "symfony",
        "testing",
        "api",
        "phpunit",
        "json-schema"
    ],
    "require": {
        "php": ">=8.3",
        "justinrainbow/json-schema": "^6.0",
        "mtdowling/jmespath.php": "^2.8",
        "symfony/browser-kit": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-foundation": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "doctrine/orm": "^3.6",
        "doctrine/doctrine-bundle": "^2.18 || ^3.2",
        "symfony/messenger": "^6.4 || ^7.0 || ^8.0",
        "symfony/mailer": "^6.4 || ^7.0 || ^8.0",
        "symfony/notifier": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-client": "^6.4 || ^7.0 || ^8.0",
        "symfony/cache": "^6.4 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.4 || ^7.0 || ^8.0",
        "zenstruck/foundry": "^2.9"
    },
    "suggest": {
        "doctrine/orm": "Required for InteractsWithDatabase",
        "doctrine/doctrine-bundle": "Required for assertQueryCount* in InteractsWithProfiler",
        "symfony/messenger": "Required for InteractsWithMessenger",
        "symfony/mailer": "Required for InteractsWithMailer",
        "symfony/notifier": "Required for InteractsWithNotifier",
        "symfony/http-client": "Required for InteractsWithHttpClient",
        "symfony/cache": "Required for InteractsWithCache",
        "zenstruck/foundry": "Recommended for test data factories"
    },
    "autoload": {
        "psr-4": {
            "Tyloo\\Atc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tyloo\\Atc\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "minimum-stability": "stable"
}
